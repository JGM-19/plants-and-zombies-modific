{
	"schemaVersion": 1,
	"id": "plantz",
	"version": "${version}",
	"name": "Plants & Zombies",
	"description": "Find and grow helpful Plants that can defend your base.",
	"authors": [
		"joshxviii"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/plantz/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "joshxviii.plantz.PazMain",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "joshxviii.plantz.PazClient",
				"adapter": "kotlin"
			}
		],
		"terrablender": [
			{
				"value": "joshxviii.plantz.PazWorldGen",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"plantz.mixins.json",
		{
			"config": "plantz.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.14.22",
		"minecraft": "1.20.1",
		"java": ">=17",
		"fabric-api": ">=0.90.0+1.20.1*",
		"fabric-language-kotlin": ">=1.11.0+kotlin.2.0.0"
	}
}
